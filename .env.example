# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Note: Cloudinary is no longer required as images are now stored locally via SQLite in the backend.

# --- Backend Configuration (For /backend/.env) ---
# You can copy the following variables into a file named `/backend/.env` on your local PC.
# SECRET_KEY: Used for encrypting JWT tokens. Change this to a random string in production.
# ALGORITHM: Encryption algorithm for tokens. Usually HS256.
# ACCESS_TOKEN_EXPIRE_MINUTES: How long until a login session expires across the system.
# DATABASE_URL: Path to the SQLite database where all users, presets, and photos are stored.

SECRET_KEY="supersecretkey_change_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
DATABASE_URL="sqlite:///./sql_app.db"